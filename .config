{
  "project": {
    "name": "Biomedproject",
    "description": "Batch effects in multi-center PET/CT radiomics using HECKTOR 2025 and nnU-Net",
    "authors": [
      "Jakob Morales",
      "Sumant Tiwari"
    ]
  },

  "paths": {
    "project_root": ".",
    "raw_zip": "data/raw/HECKTOR_2025_Training_Data_Defaced_ALL.zip",
    "extracted_root": "data/extracted/HECKTOR 2025 Training Data Defaced ALL",
    "processed_root": "data/processed",
    "figures_root": "figures",

    "nnunet_root": "local_nnunet",
    "nnunet_raw": "local_nnunet/nnUNet_raw",
    "nnunet_preprocessed": "local_nnunet/nnUNet_preprocessed",
    "nnunet_results": "local_nnunet/nnUNet_results",
    "predictions_root": "local_nnunet/predictions",
    "results_root": "local_nnunet/results"
  },

  "dataset": {
    "expected_centers": [
      "CHUM",
      "CHUP",
      "CHUS",
      "HGJ",
      "HMR",
      "MDA",
      "USZ"
    ],
    "ct_suffix": "__CT.nii.gz",
    "pet_suffix": "__PT.nii.gz",
    "mask_suffix": ".nii.gz",
    "ignore_suffixes": [
      "__RTDOSE.nii.gz"
    ],
    "label_definitions": {
      "0": "background",
      "1": "GTVp_primary_tumor",
      "2": "GTVn_nodal_tumor"
    }
  },

  "quality_control": {
    "valid_extensions": [
      ".nii.gz",
      ".nii",
      ".mha",
      ".mhd",
      ".nrrd"
    ],
    "hu_clip_min": -1000,
    "hu_clip_max": 400,
    "abnormal_low_threshold": -2000,
    "abnormal_high_threshold": 5000,
    "require_ct": true,
    "require_pet": true,
    "require_mask": true
  },

  "preprocessing": {
    "target_spacing_xyz": [
      1.0,
      1.0,
      1.0
    ],
    "normalization_modes": [
      "raw",
      "normalized"
    ],
    "default_normalization_mode": "raw",
    "hu_clip_min": -1000,
    "hu_clip_max": 400,
    "zscore_epsilon": 1e-6,
    "crop_mode": "none",
    "mask_crop_margin_voxels": 20
  },

  "nnunet": {
    "dataset_name_prefix": "HECKTOR",
    "dataset_id_start": 1,
    "configuration": "3d_fullres",
    "fold": 0,
    "trainer": "nnUNetTrainer",
    "plans": "nnUNetPlans",
    "checkpoint_for_inference": "checkpoint_best.pth",
    "label_mode": "binary",
    "binary_label_mapping": {
      "0": 0,
      "1": 1,
      "2": 1
    },
    "multiclass_label_mapping": {
      "0": 0,
      "1": 1,
      "2": 2
    }
  },

  "evaluation": {
    "foreground_labels": [
      1
    ],
    "metrics": [
      "dice",
      "iou",
      "sensitivity",
      "specificity",
      "precision",
      "accuracy"
    ],
    "statistical_tests": [
      "one_way_anova",
      "levene"
    ],
    "alpha": 0.05
  },

  "visualization": {
    "ct_window_min": -200,
    "ct_window_max": 300,
    "pet_lower_percentile": 1,
    "pet_upper_percentile": 99.5,
    "pet_alpha": 0.45,
    "pet_threshold": 0.08,
    "roi_margin_pixels": 35,
    "ground_truth_contour_color": "cyan",
    "prediction_contour_color": "magenta",
    "gtvp_color": "red",
    "gtvn_color": "cyan"
  },

  "quartz": {
    "project_dir": "/N/project/YOUR_PROJECT_NAME",
    "partition": "gpu",
    "account": "YOUR_ACCOUNT",
    "time": "24:00:00",
    "cpus_per_task": 8,
    "mem": "64G",
    "gpus": 1,
    "mail_user": "your_email@iu.edu",
    "mail_type": "END,FAIL"
  }
}
